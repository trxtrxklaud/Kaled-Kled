# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ── Firebase backend (FREE Spark plan) ──────────────────────────
# Get these from: Firebase Console > Project Settings > Your apps > Web app
# The apiKey is NOT secret — security is enforced by firestore.rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Leave empty to use the "(default)" Firestore database, or set a named DB id.
VITE_FIREBASE_DATABASE_ID=

# Tenant key — ONE value per school. Each school's data is isolated
# under schools/{VITE_SCHOOL_ID}/... in Firestore. Use a short slug.
# Example: providence, al-amal, ibn-sina
VITE_SCHOOL_ID=providence

# ── Authentication ───────────────────────────────────────────────────────────

# ── Authentication ─────────────────────────────────────────────────────────
#
# PRODUCTION: staff/admin/teacher accounts are REAL Firebase Email/Password
# users with a role profile at users/{uid}. Enable Email/Password in the
# Firebase console, then bootstrap the first admin with:  node scripts/seed.mjs
#
# Once real accounts exist, disable the built-in bootstrap accounts below by
# setting:  VITE_ALLOW_LEGACY_LOGIN=false
VITE_ALLOW_LEGACY_LOGIN=true

# Seed script (scripts/seed.mjs) — first admin account to create.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change_me_strong_password
SEED_ADMIN_NAME=المدير العام

# Bootstrap admin credentials (Tier 1 — full access; first-run/offline only)
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=change_me_strong_password

# Arabic-interface admin account (Tier 1 — same access, Arabic UI default)
VITE_AR_ADMIN_USERNAME=محمد
VITE_AR_ADMIN_PASSWORD=change_me_strong_password

# Staff credentials (Tier 2 — shared account)
VITE_STAFF_USERNAME=staff
VITE_STAFF_PASSWORD=change_me_strong_password

# Teacher shared password (Tier 3 — individual usernames like prof1, prof2…)
VITE_TEACHER_PASSWORD=change_me_strong_password

# ── Email ────────────────────────────────────────────────────────────────────

# Director / manager email used by report, certificate and analytics dispatch
VITE_MANAGER_EMAIL=director@example.com

# EmailJS — client-side email (up to 3 attachments)
# Template must expose: to_email, subject, message,
#   attachment_1_name, attachment_1_content,
#   attachment_2_name, attachment_2_content,
#   attachment_3_name, attachment_3_content
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# SMTP / backend API — preferred for production (no attachment size limit)
# Expected POST body: { to, subject, message, attachments: [{ fileName, content, type }] }
VITE_SMTP_API_ENDPOINT=
VITE_SMTP_API_KEY=

# ── Eduserv integration ──────────────────────────────────────────────────────

# Backend sync endpoint
# Expected response: { students?: [], academicResults?: [], exams?: [], message?: string }
VITE_EDUSERV_SYNC_ENDPOINT=
VITE_EDUSERV_API_KEY=
VITE_EDUSERV_API_SECRET=

# ── Files ────────────────────────────────────────────────────────────────────

# Base URL for timetable/schedule files hosted on your server.
# Used to build download links from stored file names.
# Must end with a trailing slash.
# Example (local dev):  http://localhost:3000/files/
# Example (production): https://school.providence.ma/files/
VITE_SERVER_BASE_URL=https://school.providence.ma/files/
